{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Flask App",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "FLASK_ENV": "development",
                "PYTHONUNBUFFERED": "1"
            },
            "jinja": true,
            "justMyCode": true
        }
    ]
}